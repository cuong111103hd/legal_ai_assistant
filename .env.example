# Choose one or both providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...


LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Groq (primary LLM provider — free tier)
GROQ_API_KEY=gsk_...
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Qdrant vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=vietnamese_legal
# Set to true for dev without Docker (in-memory, data lost on restart)
QDRANT_IN_MEMORY=false

# OpenSearch search engine
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# Neo4j graph database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=legal_pass

# Redis cache
REDIS_URL=redis://localhost:6379

# Embedding model
EMBEDDING_MODEL=Quockhanh05/Vietnam_legal_embeddings
EMBEDDING_DIM=768
EMBEDDING_BATCH_SIZE=32

# Dataset
DATASET_NAME=th1nhng0/vietnamese-legal-documents

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval
TOP_K=10
RRF_K=60
CONTEXT_WINDOW=1

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legal_assistant
POSTGRES_USER=legal_user
POSTGRES_PASSWORD=legal_pass

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log

# LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2-...
LANGCHAIN_PROJECT=legal-ai-assistant
